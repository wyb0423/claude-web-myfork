<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.claude.web.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.claude.web.entity.User">
        <id     column="id"              property="id"/>
        <result column="username"        property="username"/>
        <result column="password"        property="password"/>
        <result column="role"            property="role"/>
        <result column="status"          property="status"/>
        <result column="create_time"     property="createTime"/>
        <result column="last_login_time" property="lastLoginTime"/>
    </resultMap>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM t_users WHERE username = #{username} LIMIT 1
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM t_users
    </select>

    <insert id="insert" parameterType="com.claude.web.entity.User">
        INSERT INTO t_users (username, password, role, status)
        VALUES (#{username}, #{password}, #{role}, #{status})
    </insert>

    <update id="updateLastLoginTime">
        UPDATE t_users SET last_login_time = #{lastLoginTime} WHERE id = #{id}
    </update>

</mapper>
